int lo0
ip add 172.16.4.1 255.255.255.255
!
int e0/1
ip add 10.0.2.1 255.255.255.252
ip ospf network point-to-point
!
int e0/2
ip add 10.0.2.5 255.255.255.252
ip ospf network point-to-point
!
router ospf 1
router-id 172.16.4.1
prefix-suppression
network 172.16.4.1 0.0.0.0 area 0
network 10.0.2.4 0.0.0.3 area 0
!
router bgp 400
bgp router-id interface lo0
no bgp default ipv4-unicast 
!
neighbor 10.0.2.2 remote-as 100
neighbor 172.16.4.2 remote-as 400
neighbor 172.16.4.2 update-source Loopback0
neighbor 172.16.4.3 remote-as 400
neighbor 172.16.4.3 update-source Loopback0
!
address-family ipv4 unicast 
!
neighbor 10.0.2.2 activate
neighbor 10.0.2.2 next-hop-self
neighbor 172.16.4.2 activate
neighbor 172.16.4.2 next-hop-self
neighbor 172.16.4.3 activate
neighbor 172.16.4.3 next-hop-self
!