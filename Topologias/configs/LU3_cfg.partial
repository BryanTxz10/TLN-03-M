int lo0
ip add 172.16.5.3 255.255.255.255
!
int e0/1
ip add 10.0.3.13 255.255.255.252
ip ospf network point-to-point
!
int e0/2
ip add 10.0.3.10 255.255.255.252
ip ospf network point-to-point
!
router ospf 1
router-id 172.16.5.3
prefix-suppression
network 172.16.5.3 0.0.0.0 area 0
network 10.0.3.8 0.0.0.3 area 0
!
router bgp 500
bgp router-id interface Loopback0
no bgp default ipv4-unicast 
!
neighbor 172.16.5.1 remote-as 500
neighbor 172.16.5.1 update-source Loopback0
neighbor 172.16.5.2 remote-as 500
neighbor 172.16.5.2 update-source Loopback0
neighbor 10.0.3.14 remote-as 700
!
address-family ipv4 unicast 
neighbor 172.16.5.1 activate
neighbor 172.16.5.1 next-hop-self
neighbor 172.16.5.2 activate
neighbor 172.16.5.2 next-hop-self
neighbor 10.0.3.14 activate
neighbor 10.0.3.14 next-hop-self
!

