!
interface Loopback0
 ip address 172.16.1.2 255.255.255.255
!
interface Ethernet0/1
 ip address 10.0.0.6 255.255.255.252
 ip ospf network point-to-point
!
interface Ethernet0/2
 ip address 10.0.0.17 255.255.255.252
 ip ospf network point-to-point
!
interface Ethernet0/3
 ip address 10.0.1.2 255.255.255.252
!
interface Ethernet1/1
 ip address 10.0.2.2 255.255.255.252
!
router ospf 10
 router-id 172.16.1.2
 prefix-suppression
 network 10.0.0.4 0.0.0.3 area 0
 network 10.0.0.16 0.0.0.3 area 0
 network 172.16.1.2 0.0.0.0 area 0
!
router bgp 100
 bgp router-id 172.16.1.2
 bgp log-neighbor-changes
 no bgp default ipv4-unicast
 neighbor 172.16.1.1 remote-as 100
 neighbor 172.16.1.1 update-source Loopback0
 neighbor 172.16.1.3 remote-as 100
 neighbor 172.16.1.3 update-source Loopback0
 neighbor 172.16.1.4 remote-as 100
 neighbor 172.16.1.4 update-source Loopback0
 neighbor 10.0.1.1 remote-as 300
 neighbor 10.0.2.1 remote-as 400
 
 !
 address-family ipv4
  neighbor 172.16.1.1 activate
  neighbor 172.16.1.1 next-hop-self
  neighbor 172.16.1.3 activate
  neighbor 172.16.1.3 next-hop-self
  neighbor 172.16.1.4 activate
  neighbor 172.16.1.4 next-hop-self
  neighbor 10.0.1.1 activate
  neighbor 10.0.1.1 route-map RM-PUB-MOVISTAR out
  neighbor 10.0.1.1 route-map RM-EXTERNOS in
  neighbor 10.0.2.1 activate
  neighbor 10.0.2.1 route-map RM-PUB-MOVISTAR out
  neighbor 10.0.2.1 route-map RM-EXTERNOS in
 exit-address-family
!
ip prefix-list PL-EXTERNOS seq 5 deny 200.0.0.0/29
ip prefix-list PL-EXTERNOS seq 10 deny 200.0.1.0/29
ip prefix-list PL-EXTERNOS seq 15 permit 0.0.0.0/0 le 32
ip prefix-list PL-PUB-MOVISTAR seq 5 permit 200.0.0.0/29
ip prefix-list PL-PUB-MOVISTAR seq 10 permit 200.0.1.0/29
!
route-map RM-PUB-MOVISTAR permit 10 
 match ip address prefix-list PL-PUB-MOVISTAR
route-map RM-EXTERNOS permit 10 
 match ip address prefix-list PL-EXTERNOS
!
ip forward-protocol nd
!
!
ip ftp username dubuntu
ip ftp password 123456
