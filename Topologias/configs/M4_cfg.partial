!
interface Loopback0
 ip address 172.16.1.4 255.255.255.255
!
interface Ethernet0/0
 description clab-mgmt
 vrf forwarding clab-mgmt
 ip address 172.20.20.3 255.255.255.0
 ipv6 address 3FFF:172:20:20::3/64
!
interface Ethernet0/1
 ip address 10.0.0.10 255.255.255.252
 ip ospf network point-to-point
 mpls ip
!
interface Ethernet0/2
 ip address 10.0.0.14 255.255.255.252
 ip ospf network point-to-point
 mpls ip
!
interface Ethernet0/3
 ip address 10.0.0.18 255.255.255.252
 ip ospf network point-to-point
 mpls ip
!
interface Ethernet1/0
 ip address 10.0.0.25 255.255.255.252
!
interface Ethernet1/1
 ip address 10.0.0.29 255.255.255.252
!
interface Ethernet1/2
 no ip address
 shutdown
!
interface Ethernet1/3
 no ip address
 shutdown
!
router ospf 10
 router-id 172.16.1.4
 passive-interface default
 no passive-interface Ethernet0/1
 no passive-interface Ethernet0/2
 no passive-interface Ethernet0/3
 network 10.0.0.8 0.0.0.3 area 0
 network 10.0.0.12 0.0.0.3 area 0
 network 10.0.0.16 0.0.0.3 area 0
 network 172.16.1.4 0.0.0.0 area 0
!
router bgp 100
 bgp router-id 172.16.1.4
 bgp log-neighbor-changes
 neighbor 172.16.1.2 remote-as 100
 neighbor 172.16.1.2 update-source Loopback0
 neighbor 172.16.1.2 next-hop-self
 neighbor 172.16.1.3 remote-as 100
 neighbor 172.16.1.3 update-source Loopback0
 !
 address-family ipv4
  neighbor 10.0.0.26 activate
  neighbor 10.0.0.26 route-map RM-PUB-MOVISTAR out
  neighbor 10.0.0.26 route-map RM-EXTERNOS in
  neighbor 10.0.0.30 activate
  neighbor 10.0.0.30 route-map RM-PUB-MOVISTAR out
  neighbor 10.0.0.30 route-map RM-EXTERNOS in
  neighbor 172.16.1.1 activate
  neighbor 172.16.1.1 next-hop-self
  neighbor 172.16.1.2 activate
  neighbor 172.16.1.2 next-hop-self
  neighbor 172.16.1.3 activate
  neighbor 172.16.1.3 next-hop-self
 exit-address-family
!
ip prefix-list PL-EXTERNOS seq 5 deny 200.0.0.0/29
ip prefix-list PL-EXTERNOS seq 10 deny 200.0.1.0/29
ip prefix-list PL-EXTERNOS seq 15 permit 0.0.0.0/0 le 32
ip prefix-list PL-PUB-MOVISTAR seq 5 permit 200.0.0.0/29
ip prefix-list PL-PUB-MOVISTAR seq 10 permit 200.0.1.0/29
!
route-map RM-PUB-MOVISTAR permit 10 
 match ip address prefix-list PL-PUB-MOVISTAR
route-map RM-EXTERNOS permit 10 
 match ip address prefix-list PL-EXTERNOS
!
ip forward-protocol nd
!
!
ip ftp username dubuntu
ip ftp password 123456
ip http server
ip http secure-server
ip route vrf clab-mgmt 0.0.0.0 0.0.0.0 Ethernet0/0 172.20.20.1
ip ssh bulk-mode 131072
!
ipv6 route vrf clab-mgmt ::/0 Ethernet0/0 3FFF:172:20:20::1
!
mpls ldp router-id Loopback0 force
!
!
!
control-plane
!
!
!
line con 0
 logging synchronous
line aux 0
line vty 0 4
 login local
 transport input ssh
!
!
!
!
