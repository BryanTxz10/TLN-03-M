track 10 ip route 192.168.10.0 255.255.255.0 reachability
track 20 ip route 192.168.20.0 255.255.255.0 reachability
!
crypto isakmp policy 10
 encr aes
 hash md5
 authentication pre-share
 group 5
 lifetime 1000
crypto isakmp key TLN03 address 200.0.0.1 
!
crypto ipsec transform-set TS-TO-HQ esp-3des esp-md5-hmac 
 mode transport
!
crypto ipsec profile PF-TO-HQ
 set transform-set TS-TO-HQ
!
interface Loopback0
 ip address 192.168.10.254 255.255.255.255
!
interface Ethernet0/0
 description clab-mgmt
 vrf forwarding clab-mgmt
 ip address 172.20.20.16 255.255.255.0
 ipv6 address 3FFF:172:20:20::10/64
 ipv6 address 3FFF:172:20:20::13/64
!
interface Ethernet0/1
 ip address 10.0.0.62 255.255.255.252
 ip nat outside
!
interface Ethernet0/2
 no ip address 
 no shutdown
!
interface Ethernet0/2.5
 encapsulation dot1q 5
 ip address 192.168.5.2 255.255.255.0
 ip nat inside
 vrrp 5 ip 192.168.5.1
 vrrp 5 preempt
 vrrp 5 track 10
 vrrp 5 track 20
 no shutdown
!
interface Ethernet0/2.15
 encapsulation dot1q 15 
 ip address 192.168.15.2 255.255.255.0
 ip nat inside
 vrrp 15 ip 192.168.15.1
 vrrp 15 preempt
 vrrp 15 track 10
 vrrp 15 track 20
 no shutdown
!
interface Ethernet0/3
 no ip address
 shutdown
!
interface Tunnel1
 ip address 172.16.10.2 255.255.255.252
 tunnel source 190.0.0.1
 tunnel destination 200.0.0.1
 ip ospf hello-interval 5
 ip ospf dead-interval 20
 tunnel protection ipsec profile PF-TO-HQ
!
router ospf 10
router-id 2.2.2.2
passive-interface ethernet0/2.5
passive-interface ethernet0/2.15
network 172.16.10.0 0.0.0.3 area 0
network 192.168.5.0 0.0.0.255 area 0
network 192.168.15.0 0.0.0.255 area 0
!
ip access-list standard 10
 10 permit 192.168.5.0 0.0.0.255
 20 permit 192.168.15.0 0.0.0.255
!
ip nat pool BRANCH-POOL 190.0.0.2 190.0.0.6 prefix-length 29
ip nat inside source list 10 pool BRANCH-POOL overload
!
ip forward-protocol nd
!
!
ip ftp username dubuntu
ip ftp password 123456
ip http server
ip http secure-server
ip route 0.0.0.0 0.0.0.0 10.0.0.61
!
ip ftp username dubuntu
ip ftp password 123456